# ============================================================
# REQUIRED — the bot will not start without these
# ============================================================

# Slack Socket Mode app
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
ALLOWED_SLACK_USER_ID=

# ============================================================
# OPTIONAL — bootstrap config
# Missing values use defaults or disable the corresponding feature.
# ============================================================

# AWS Bedrock (agent loop against Claude Sonnet)
# AWS_REGION is optional; if unset, the SDK default chain
# resolves it from ~/.aws/config, AWS_DEFAULT_REGION, or SSO.
# AWS_PROFILE is optional; if unset, the SDK uses `default`.
AWS_PROFILE=
AWS_REGION=
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# ============================================================
# Observability
# ============================================================
LOG_LEVEL=info

# Optional: where to store conversation history (default: ./tino.db)
# Only used when PERSISTENCE_ADAPTER=sqlite (the default).
DB_PATH=

# ============================================================
# Persistence adapter
# ============================================================

# Which persistence backend to use. Default: sqlite (local dev).
# Set to 'dynamodb' in production (requires DYNAMODB_TABLE_NAME).
PERSISTENCE_ADAPTER=

# DynamoDB table name. Required when PERSISTENCE_ADAPTER=dynamodb.
# The table is created by the CDK stack (infra/lib/tino-stack.ts).
# Uses the AWS SDK default credential chain (same as Bedrock/CloudWatch).
DYNAMODB_TABLE_NAME=

# ============================================================
# Legacy migration vars (optional — remove after first startup)
# ============================================================
# On first startup, if these are set, they are automatically migrated
# to capability configs in the config table. After migration, you can
# remove them from .env and manage credentials via the web console at
# localhost:3001.

# GitHub PAT — classic token with `repo` scope for private repos.
GITHUB_TOKEN=
GITHUB_DEFAULT_REPO=

# Google OAuth Desktop client
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Slack user token (xoxp-) for reading channels as the owner.
SLACK_USER_TOKEN=

# Linear developer token (OAuth app token).
LINEAR_DEVELOPER_TOKEN=
