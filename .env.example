# Slack Socket Mode app (see plan Phase 2 for setup steps)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
ALLOWED_SLACK_USER_ID=

# AWS (default credential chain; AWS_PROFILE optional)
AWS_PROFILE=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0

# GitHub PAT (classic) — repo scope for private repos
GITHUB_TOKEN=

# Google OAuth (Desktop app client; see plan Phase 6 / Phase 7 for setup)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Observability
LOG_LEVEL=info
