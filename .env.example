# ============================================================
# REQUIRED — the bot will not start without these
# ============================================================

# Slack Socket Mode app (see plan Phase 2 for setup steps)
SLACK_BOT_TOKEN=
SLACK_APP_TOKEN=
ALLOWED_SLACK_USER_ID=

# ============================================================
# OPTIONAL — each enables a set of tools / providers
# Missing values disable the corresponding feature; they do NOT
# crash the bot.
# ============================================================

# AWS Bedrock (Phase 3 — agent loop against Claude Sonnet)
# AWS_REGION is optional; if unset, the SDK default chain
# resolves it from ~/.aws/config, AWS_DEFAULT_REGION, or SSO.
# AWS_PROFILE is optional; if unset, the SDK uses `default`.
AWS_PROFILE=
AWS_REGION=
BEDROCK_MODEL_ID=global.anthropic.claude-sonnet-4-6

# GitHub PAT (Phase 4 — github_search_code, github_get_file)
# Classic token with `repo` scope for private repos; no scope for public.
GITHUB_TOKEN=

# Optional: default repo (owner/repo) to use when Claude doesn't specify one.
# Must be in the allowlist at src/tools/github/allowlist.ts.
GITHUB_DEFAULT_REPO=

# Google OAuth Desktop client (Phase 6 calendar + Phase 7 gmail)
# See plan for setup; refresh token is generated via scripts/google-auth.ts
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=
GOOGLE_OAUTH_REFRESH_TOKEN=

# Slack user token (Phase 10 — slack_search_messages, slack_read_thread)
# Obtained via Slack OAuth flow with user scopes: search:read, channels:history, groups:history.
# This is the owner's personal token (xoxp-), NOT the bot token (xoxb-).
# It reads channels as the owner — sees exactly what the owner sees.
SLACK_USER_TOKEN=

# Linear developer token (OAuth app token) for Linear issue tools.
# Enables: linear_search_issues, linear_get_issue, linear_create_issue,
#          linear_update_issue, linear_add_comment, linear_list_my_issues.
# Obtain from Linear → Settings → API → Personal API keys (or OAuth app token).
LINEAR_DEVELOPER_TOKEN=

# ============================================================
# Observability
# ============================================================
LOG_LEVEL=info

# Optional: where to store conversation history (default: ./tino.db)
# Only used when PERSISTENCE_ADAPTER=sqlite (the default).
DB_PATH=

# ============================================================
# Persistence adapter
# ============================================================

# Which persistence backend to use. Default: sqlite (local dev).
# Set to 'dynamodb' in production (requires DYNAMODB_TABLE_NAME).
PERSISTENCE_ADAPTER=

# DynamoDB table name. Required when PERSISTENCE_ADAPTER=dynamodb.
# The table is created by the CDK stack (infra/lib/tino-stack.ts).
# Uses the AWS SDK default credential chain (same as Bedrock/CloudWatch).
DYNAMODB_TABLE_NAME=
