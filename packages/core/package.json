{
  "name": "@tino/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./agent/history": {
      "types": "./dist/agent/history.d.ts",
      "default": "./dist/agent/history.js"
    },
    "./persistence/tasks": {
      "types": "./dist/persistence/tasks.d.ts",
      "default": "./dist/persistence/tasks.js"
    },
    "./persistence/preferences": {
      "types": "./dist/persistence/preferences.d.ts",
      "default": "./dist/persistence/preferences.js"
    },
    "./persistence/config": {
      "types": "./dist/persistence/config.d.ts",
      "default": "./dist/persistence/config.js"
    },
    "./persistence/factory": {
      "types": "./dist/persistence/factory.d.ts",
      "default": "./dist/persistence/factory.js"
    },
    "./slack/app": {
      "types": "./dist/slack/app.d.ts",
      "default": "./dist/slack/app.js"
    },
    "./audit/logger": {
      "types": "./dist/audit/logger.d.ts",
      "default": "./dist/audit/logger.js"
    },
    "./audit/memory": {
      "types": "./dist/audit/memory.d.ts",
      "default": "./dist/audit/memory.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "ai": "^6.0.178",
    "@ai-sdk/amazon-bedrock": "^4.0.105",
    "@aws-sdk/credential-providers": "^3.1045.0",
    "@slack/bolt": "^4.7.2",
    "zod": "^4.4.3",
    "dotenv": "^17.4.2",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "@octokit/rest": "^22.0.1",
    "googleapis": "^171.4.0",
    "@linear/sdk": "^84.0.0",
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "better-sqlite3": "^12.10.0",
    "@smithy/node-http-handler": "^4.7.1",
    "@smithy/fetch-http-handler": "^5.4.1"
  },
  "devDependencies": {
    "typescript": "^6.0.3",
    "tsx": "^4.21.0",
    "vitest": "^4.1.6",
    "@types/node": "^25.7.0",
    "@types/better-sqlite3": "^7.6.13"
  }
}
