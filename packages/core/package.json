{
  "name": "@tino/core",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./env": {
      "types": "./dist/env.d.ts",
      "default": "./dist/env.js"
    },
    "./agent/history": {
      "types": "./dist/agent/history.d.ts",
      "default": "./dist/agent/history.js"
    },
    "./persistence/tasks": {
      "types": "./dist/persistence/tasks.d.ts",
      "default": "./dist/persistence/tasks.js"
    },
    "./persistence/preferences": {
      "types": "./dist/persistence/preferences.d.ts",
      "default": "./dist/persistence/preferences.js"
    },
    "./persistence/config": {
      "types": "./dist/persistence/config.d.ts",
      "default": "./dist/persistence/config.js"
    },
    "./persistence/factory": {
      "types": "./dist/persistence/factory.d.ts",
      "default": "./dist/persistence/factory.js"
    },
    "./identity/store": {
      "types": "./dist/identity/store.d.ts",
      "default": "./dist/identity/store.js"
    },
    "./identity/types": {
      "types": "./dist/identity/types.d.ts",
      "default": "./dist/identity/types.js"
    },
    "./slack/app": {
      "types": "./dist/slack/app.d.ts",
      "default": "./dist/slack/app.js"
    },
    "./audit/logger": {
      "types": "./dist/audit/logger.d.ts",
      "default": "./dist/audit/logger.js"
    },
    "./audit/memory": {
      "types": "./dist/audit/memory.d.ts",
      "default": "./dist/audit/memory.js"
    },
    "./capabilities/types": {
      "types": "./dist/capabilities/types.d.ts",
      "default": "./dist/capabilities/types.js"
    },
    "./crypto/types": {
      "types": "./dist/crypto/types.d.ts",
      "default": "./dist/crypto/types.js"
    },
    "./crypto/factory": {
      "types": "./dist/crypto/factory.d.ts",
      "default": "./dist/crypto/factory.js"
    },
    "./persistence/user-capabilities": {
      "types": "./dist/persistence/user-capabilities.d.ts",
      "default": "./dist/persistence/user-capabilities.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json && vite build",
    "build:server": "tsc -p tsconfig.build.json",
    "build:console": "vite build",
    "dev": "tsx watch src/index.ts",
    "dev:console": "vite",
    "lint": "biome check .",
    "start": "tsx src/index.ts",
    "test": "bun --bun ./node_modules/vitest/dist/cli.js run",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.app.json"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^4.0.105",
    "@aws-sdk/client-cloudwatch-logs": "^3.1045.0",
    "@aws-sdk/credential-providers": "^3.1045.0",
    "@hono/node-server": "^2.0.2",
    "@linear/sdk": "^84.0.0",
    "@octokit/rest": "^22.0.1",
    "@slack/bolt": "^4.7.2",
    "@slack/web-api": "^7.15.1",
    "ai": "^6.0.178",
    "better-auth": "^1.6.11",
    "dotenv": "^17.4.2",
    "googleapis": "^171.4.0",
    "hono": "^4.12.18",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^25.7.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.13",
    "vitest": "^4.1.6"
  }
}
