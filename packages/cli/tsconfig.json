{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": ".",
    "outDir": "dist",
    "noEmit": true,
    "types": ["node"],
    "paths": {
      "@tino/core": ["../core/src/index.ts"],
      "@tino/core/*": ["../core/src/*"],
      "@tino/aws": ["../aws/src/index.ts"],
      "@tino/aws/*": ["../aws/src/*"]
    }
  },
  "include": ["src/**/*"]
}
