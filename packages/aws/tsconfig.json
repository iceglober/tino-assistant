{
  "compilerOptions": {
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2022",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "rootDir": "../",
    "outDir": "dist",
    "noEmit": true,
    "types": ["node", "bun"],
    "paths": {
      "@tino/core": ["../core/src/index.ts"],
      "@tino/core/env": ["../core/src/env.ts"],
      "@tino/core/agent/history": ["../core/src/agent/history.ts"],
      "@tino/core/persistence/tasks": ["../core/src/persistence/tasks.ts"],
      "@tino/core/persistence/preferences": ["../core/src/persistence/preferences.ts"],
      "@tino/core/persistence/config": ["../core/src/persistence/config.ts"],
      "@tino/core/persistence/factory": ["../core/src/persistence/factory.ts"],
      "@tino/core/slack/app": ["../core/src/slack/app.ts"]
    }
  },
  "include": ["src/**/*"]
}
