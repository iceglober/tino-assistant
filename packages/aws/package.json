{
  "name": "@tino/aws",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./persistence": {
      "types": "./dist/persistence/factory.d.ts",
      "default": "./dist/persistence/factory.js"
    },
    "./audit": {
      "types": "./dist/audit/dynamo.d.ts",
      "default": "./dist/audit/dynamo.js"
    },
    "./pulumi": {
      "types": "./dist/pulumi/index.d.ts",
      "default": "./dist/pulumi/index.js"
    },
    "./encryption": {
      "types": "./dist/encryption/index.d.ts",
      "default": "./dist/encryption/index.js"
    }
  },
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.1045.0",
    "@aws-sdk/client-kms": "^3.1045.0",
    "@aws-sdk/lib-dynamodb": "^3.1045.0",
    "dynamodb-toolbox": "^2.8.0",
    "@smithy/node-http-handler": "^4.7.1",
    "ai": "^6.0.178"
  },
  "peerDependencies": {
    "@tino/core": "workspace:*",
    "@pulumi/aws": ">=6.0.0",
    "@pulumi/pulumi": ">=3.0.0",
    "@pulumi/docker-build": ">=0.0.17"
  },
  "devDependencies": {
    "@pulumi/aws": "^6.0.0",
    "@pulumi/docker-build": "^0.0.17",
    "@pulumi/pulumi": "^3.0.0",
    "@types/node": "^25.7.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.6"
  }
}
